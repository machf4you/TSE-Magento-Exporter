<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Backend:etc/menu.xsd">
    <menu>
        <!--
            Group node — renders as a labelled section under the System menu.
            Has no `action` attribute, so it's just a header for its children.
        -->
        <add id="TSE_MagentoExporter::tse_root"
             title="TSE Magento Exporter"
             translate="title"
             module="TSE_MagentoExporter"
             parent="Magento_Backend::system"
             sortOrder="100"
             resource="Magento_Backend::admin"/>

        <!-- Clickable action under the group. -->
        <add id="TSE_MagentoExporter::tse_export_run"
             title="Export Site Data"
             translate="title"
             module="TSE_MagentoExporter"
             parent="TSE_MagentoExporter::tse_root"
             sortOrder="10"
             action="tsemagento/export/index"
             resource="Magento_Backend::admin"/>
    </menu>
</config>
